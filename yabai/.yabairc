#!/usr/bin/env sh

# NOTE: On macOS Sequoia, if scripting addition fails to load with:
#   "could not spawn remote thread: (os/kern) protection failure"
# You need to apply the PAC ABI patch:
#   sudo bash ~/ghq/github.com/adammomen/.dotfiles/yabai/scripts/patch-loader.sh
# See: https://github.com/asmvik/yabai/issues/2686

sudo yabai --load-sa
yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"

# Create spaces if they don't exist (ensure 10 spaces total)
for i in {1..10}; do
    yabai -m query --spaces --space $i &>/dev/null || yabai -m space --create
done

# Auto-correct window placement - enforce space assignments
# These signals trigger when windows are created and move them to correct spaces
yabai -m signal --add event=window_created app="Brave" action="sleep 0.5 && yabai -m window \$YABAI_WINDOW_ID --space 1"
yabai -m signal --add event=window_created app="Dai" action="sleep 0.5 && yabai -m window \$YABAI_WINDOW_ID --space 1"
yabai -m signal --add event=window_created app="Safari" action="sleep 0.5 && yabai -m window \$YABAI_WINDOW_ID --space 1"
yabai -m signal --add event=window_created app="Notion" action="sleep 0.5 && yabai -m window \$YABAI_WINDOW_ID --space 2"
yabai -m signal --add event=window_created app="iTerm2" action="sleep 0.5 && yabai -m window \$YABAI_WINDOW_ID --space 3"
yabai -m signal --add event=window_created app="Cursor" action="sleep 0.5 && yabai -m window \$YABAI_WINDOW_ID --space 4"
yabai -m signal --add event=window_created app="Antigravity" action="sleep 0.5 && yabai -m window \$YABAI_WINDOW_ID --space 4"
yabai -m signal --add event=window_created app="Postico 2" action="sleep 0.5 && yabai -m window \$YABAI_WINDOW_ID --space 5"
yabai -m signal --add event=window_created app="NordVPN" action="sleep 0.5 && yabai -m window \$YABAI_WINDOW_ID --space 5"
yabai -m signal --add event=window_created app="System Settings" action="sleep 0.5 && yabai -m window \$YABAI_WINDOW_ID --space 5"
yabai -m signal --add event=window_created app="App Store" action="sleep 0.5 && yabai -m window \$YABAI_WINDOW_ID --space 5"
yabai -m signal --add event=window_created app="Slack" action="sleep 0.5 && yabai -m window \$YABAI_WINDOW_ID --space 6"
yabai -m signal --add event=window_created app="Telegram" action="sleep 0.5 && yabai -m window \$YABAI_WINDOW_ID --space 7"
yabai -m signal --add event=window_created app="Discord" action="sleep 0.5 && yabai -m window \$YABAI_WINDOW_ID --space 7"
yabai -m signal --add event=window_created app="Music" action="sleep 0.5 && yabai -m window \$YABAI_WINDOW_ID --space 8"
yabai -m signal --add event=window_created app="Claude" action="sleep 0.5 && yabai -m window \$YABAI_WINDOW_ID --space 9"
yabai -m signal --add event=window_created app="ChatGPT" action="sleep 0.5 && yabai -m window \$YABAI_WINDOW_ID --space 9"
yabai -m signal --add event=window_created app="Codex" action="sleep 0.5 && yabai -m window \$YABAI_WINDOW_ID --space 9"
yabai -m signal --add event=window_created app="Zoom" action="sleep 0.5 && yabai -m window \$YABAI_WINDOW_ID --space 10"

# CONTINUOUS ENFORCEMENT: Monitor and correct windows that move unexpectedly
# This fixes the "carry/movement shuffle" bug where windows jump between spaces

# Function to enforce space assignments - checks and fixes all assigned apps
enforce_spaces() {
    yabai -m query --windows 2>/dev/null | jq -r '.[] | select(.app=="Brave" and .space!=1) | .id' | xargs -I {} yabai -m window {} --space 1 2>/dev/null
    yabai -m query --windows 2>/dev/null | jq -r '.[] | select(.app=="Dai" and .space!=1) | .id' | xargs -I {} yabai -m window {} --space 1 2>/dev/null
    yabai -m query --windows 2>/dev/null | jq -r '.[] | select(.app=="Safari" and .space!=1) | .id' | xargs -I {} yabai -m window {} --space 1 2>/dev/null
    yabai -m query --windows 2>/dev/null | jq -r '.[] | select(.app=="Notion" and .space!=2) | .id' | xargs -I {} yabai -m window {} --space 2 2>/dev/null
    yabai -m query --windows 2>/dev/null | jq -r '.[] | select(.app=="iTerm2" and .space!=3) | .id' | xargs -I {} yabai -m window {} --space 3 2>/dev/null
    yabai -m query --windows 2>/dev/null | jq -r '.[] | select(.app=="Cursor" and .space!=4) | .id' | xargs -I {} yabai -m window {} --space 4 2>/dev/null
    yabai -m query --windows 2>/dev/null | jq -r '.[] | select(.app=="Antigravity" and .space!=4) | .id' | xargs -I {} yabai -m window {} --space 4 2>/dev/null
    yabai -m query --windows 2>/dev/null | jq -r '.[] | select(.app=="Postico 2" and .space!=5) | .id' | xargs -I {} yabai -m window {} --space 5 2>/dev/null
    yabai -m query --windows 2>/dev/null | jq -r '.[] | select(.app=="NordVPN" and .space!=5) | .id' | xargs -I {} yabai -m window {} --space 5 2>/dev/null
    yabai -m query --windows 2>/dev/null | jq -r '.[] | select(.app=="System Settings" and .space!=5) | .id' | xargs -I {} yabai -m window {} --space 5 2>/dev/null
    yabai -m query --windows 2>/dev/null | jq -r '.[] | select(.app=="App Store" and .space!=5) | .id' | xargs -I {} yabai -m window {} --space 5 2>/dev/null
    yabai -m query --windows 2>/dev/null | jq -r '.[] | select(.app=="Slack" and .space!=6) | .id' | xargs -I {} yabai -m window {} --space 6 2>/dev/null
    yabai -m query --windows 2>/dev/null | jq -r '.[] | select(.app=="Telegram" and .space!=7) | .id' | xargs -I {} yabai -m window {} --space 7 2>/dev/null
    yabai -m query --windows 2>/dev/null | jq -r '.[] | select(.app=="Discord" and .space!=7) | .id' | xargs -I {} yabai -m window {} --space 7 2>/dev/null
    yabai -m query --windows 2>/dev/null | jq -r '.[] | select(.app=="Music" and .space!=8) | .id' | xargs -I {} yabai -m window {} --space 8 2>/dev/null
    yabai -m query --windows 2>/dev/null | jq -r '.[] | select(.app=="Claude" and .space!=9) | .id' | xargs -I {} yabai -m window {} --space 9 2>/dev/null
    yabai -m query --windows 2>/dev/null | jq -r '.[] | select(.app=="ChatGPT" and .space!=9) | .id' | xargs -I {} yabai -m window {} --space 9 2>/dev/null
    yabai -m query --windows 2>/dev/null | jq -r '.[] | select(.app=="Codex" and .space!=9) | .id' | xargs -I {} yabai -m window {} --space 9 2>/dev/null
    yabai -m query --windows 2>/dev/null | jq -r '.[] | select(.app=="Zoom" and .space!=10) | .id' | xargs -I {} yabai -m window {} --space 10 2>/dev/null
}

# Trigger enforcement on various events that might cause window shuffling
yabai -m signal --add event=space_changed action="enforce_spaces" label=enforce_on_space_change
yabai -m signal --add event=display_changed action="enforce_spaces" label=enforce_on_display_change  
yabai -m signal --add event=window_focused action="enforce_spaces" label=enforce_on_focus
yabai -m signal --add event=application_front_switched action="enforce_spaces" label=enforce_on_app_switch
yabai -m signal --add event=window_moved action="enforce_spaces" label=enforce_on_move

# global settings
yabai -m config mouse_follows_focus          off
yabai -m config focus_follows_mouse          off
yabai -m config window_origin_display        default
yabai -m config window_placement             second_child
yabai -m config window_shadow                on
yabai -m config window_opacity               off
yabai -m config window_opacity_duration      0.0
yabai -m config active_window_opacity        1.0
yabai -m config normal_window_opacity        0.80
yabai -m config insert_feedback_color        0xffd75f5f
yabai -m config split_ratio                  0.50
yabai -m config auto_balance                 on
yabai -m config mouse_modifier               fn
yabai -m config mouse_action1                move
yabai -m config mouse_action2                resize
yabai -m config mouse_drop_action            swap

# general space settings
yabai -m config layout                       bsp
yabai -m config top_padding                   0
yabai -m config bottom_padding                0
yabai -m config left_padding                  0
yabai -m config right_padding                 0
yabai -m config window_gap                   03

yabai -m rule --add app="Brave"     space=1
yabai -m rule --add app="Dai"       space=1
yabai -m rule --add app="Safari"    space=1
yabai -m rule --add app="Notion"    space=2
yabai -m rule --add app="iTerm2"    space=3
yabai -m rule --add app="Cursor"    space=4
yabai -m rule --add app="Antigravity" space=4
yabai -m rule --add app="Postico 2"    space=5
yabai -m rule --add app="NordVPN"      space=5
yabai -m rule --add app="System Settings" space=5
yabai -m rule --add app="App Store"    space=5
yabai -m rule --add app="Telegram"  space=7
yabai -m rule --add app="Discord"   space=7
yabai -m rule --add app="Slack"     space=7
yabai -m rule --add app="Music"     space=8
yabai -m rule --add app="Claude"     space=9
yabai -m rule --add app="ChatGPT"    space=9
yabai -m rule --add app="Codex"      space=9
yabai -m rule --add app="Zoom"      space=10

# Disable management for apps with tab issues
yabai -m rule --add app="^Finder$" manage=off
yabai -m rule --add app="^Terminal$" manage=off

echo "yabai configuration loaded.."